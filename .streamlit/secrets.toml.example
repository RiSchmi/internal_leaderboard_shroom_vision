# Copy to .streamlit/secrets.toml for local development.
# On Streamlit Community Cloud paste the same content into
# App -> Settings -> Secrets. NEVER commit the real secrets.toml.

[auth]
password = "choose-a-strong-shared-password"

[github]
# Fine-grained personal access token:
#   - Repository access: ONLY this repository
#   - Permissions: Contents -> Read and write (nothing else)
token = "github_pat_..."
repo = "your-org/ACL-August-8-2026"
branch = "main"
